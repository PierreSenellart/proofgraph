    \pgph@install{ref}\pgph@install{cref}\pgph@install{Cref}%
    \pgph@install{autoref}\pgph@install{eqref}\pgph@install{vref}%
    \ifpgph@cite\pgph@installcite\fi
  \fi
}
\newcommand\pgph@cap@cite[2][]{%
  \ifx\pgph@curproof\@empty\else
    \def\pgph@citenotearg{#1}%
    \@for\pgph@one:=#2\do{%
      \edef\pgph@k{\expandafter\pgph@trimsp\expandafter{\pgph@one}}%
      \pgph@addedge{\pgph@curproof}{cite:\pgph@k}%
      \ifx\pgph@citenotearg\@empty\else
        \expandafter\pgph@recordcitenote\expandafter{\pgph@k}{#1}%
      \fi}%
  \fi
  \pgph@saved@cite[#1]{#2}%
}
\newcommand\pgph@recordcitenote[2]{%
